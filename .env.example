VITE_API_URL=http://localhost:3000
VITE_CRM_URL=https://nd-group-ai.vercel.app

# ========================================
# API KEYS (Update these before production)
# ========================================

# Magnific AI API for render upscaling
REACT_APP_MAGNIFIC_API_KEY=your_magnific_api_key_here

# SendGrid API for email delivery
REACT_APP_SENDGRID_API_KEY=your_sendgrid_api_key_here

# Freepik API for asset management
REACT_APP_FREEPIK_API_KEY=your_freepik_api_key_here

# ========================================
# Portal Configuration
# ========================================
REACT_APP_PORTAL_NAME=Nokta Dizayn Portal v5
REACT_APP_ENVIRONMENT=development

# Email Configuration
REACT_APP_EMAIL_FROM=portal@nokta-dizayn.com
REACT_APP_EMAIL_FROM_NAME=Nokta Dizayn Portal

# ========================================
# Feature Flags
# ========================================
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_AUTO_SAVE=true
REACT_APP_ENABLE_EMAIL=false
REACT_APP_ENABLE_BATCH_EXPORT=true